# Copy to .env for local development (never commit .env)

# MongoDB — use Atlas connection string in production
MONGO_URI=mongodb://127.0.0.1:27017/cas

# Same as MONGO_URI (optional alias)
# MONGODB_URI=

# Strong random string for production (generate: openssl rand -hex 32)
JWT_SECRET=change-me-in-production

# Your deployed frontend URL (Render static site), no trailing slash
# Example: https://cas-frontend-xxxx.onrender.com
FRONTEND_URL=http://localhost:5173

# Port (Render sets PORT automatically)
# PORT=5000
